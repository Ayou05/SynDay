{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SynDay 朝夕同序",
  "version": "0.1.0",
  "identifier": "cloud.catclaw.synday",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SynDay 朝夕同序",
        "width": 390,
        "height": 844,
        "minWidth": 320,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.synday.catclaw.cloud https://*.supabase.co wss://*.goeasy.io https://*.goeasy.io; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self' https://cdn.goeasy.io"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "sounds/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "developmentTeam": "5R7CUPKMAZ",
      "minimumSystemVersion": "15.0",
      "infoPlist": "Info.ios.plist"
    },
    "android": {
      "minSdkVersion": 26,
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
